{
  "name": "@sonata-sdk/voice",
  "version": "0.1.0",
  "description": "Discord voice connection library — WebSocket gateway, UDP, RTP, encryption, DAVE/MLS",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./gateway": {
      "import": "./dist/gateway.js",
      "types": "./dist/gateway.d.ts"
    },
    "./udp": {
      "import": "./dist/udp.js",
      "types": "./dist/udp.d.ts"
    },
    "./encryption": {
      "import": "./dist/encryption.js",
      "types": "./dist/encryption.d.ts"
    },
    "./connection": {
      "import": "./dist/connection.js",
      "types": "./dist/connection.d.ts"
    },
    "./types": {
      "import": "./dist/types.js",
      "types": "./dist/types.d.ts"
    }
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "opusscript": "^0.1.1",
    "tweetnacl": "^1.0.3"
  },
  "optionalDependencies": {
    "@snazzah/davey": "^0.1.11",
    "libsodium-wrappers": "^0.7.15"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "@types/ws": "^8.18.1",
    "typescript": "^5.4.0",
    "ws": "^8.21.0"
  }
}
