{
  "name": "@sonata-sdk/decoder",
  "version": "0.3.1",
  "description": "Audio decoders (MP3, FLAC, AAC) for Node.js — no native dependencies, no WASM wrappers",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./mp3": {
      "import": "./dist/mp3.js",
      "types": "./dist/mp3.d.ts"
    },
    "./flac": {
      "import": "./dist/flac.js",
      "types": "./dist/flac.d.ts"
    },
    "./aac": {
      "import": "./dist/aac.js",
      "types": "./dist/aac.d.ts"
    }
  },
  "files": [
    "dist",
    "wasm",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@audio/decode-flac": "^1.0.0",
    "@audio/decode-mp3": "^1.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "typescript": "^5.4.0"
  }
}
